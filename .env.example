# ── Base de datos PostgreSQL (Supabase) ──
# Conexión DIRECTA (puerto 5432) → para la migración:
DATABASE_MIGRATION_URL=<tu URL "Direct connection", con la contraseña real>

# Conexión POOLER (puerto 6543) → para runtime:
DATABASE_URL=<tu URL "Transaction pooler", con la contraseña real>

# ── Google Drive (descarga de los Excel fuente — sync_drive.py) ──
DRIVE_FOLDER_ID=...
DRIVE_CREDENTIALS_PATH=credentials/service_account.json

# ── Supabase Storage (backups offsite de Postgres) ──
# Los dumps de backup_postgres.ps1 se suben al bucket privado "backups".
# SUPABASE_URL: https://<project-ref>.supabase.co  (el <ref> es el subdominio del host directo)
# SUPABASE_SERVICE_KEY: la service_role key (Dashboard > Settings > API). Es secreta:
#   da acceso total saltándose RLS — solo en .env del servidor, nunca en el cliente.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role key>
# Opcional, default "backups":
# SUPABASE_BACKUP_BUCKET=backups