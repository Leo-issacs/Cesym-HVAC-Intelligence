# ── Base de datos PostgreSQL (Supabase) ──
# Conexión DIRECTA (puerto 5432) → para la migración:
DATABASE_MIGRATION_URL=<tu URL "Direct connection", con la contraseña real>

# Conexión POOLER (puerto 6543) → para runtime:
DATABASE_URL=<tu URL "Transaction pooler", con la contraseña real>

# ── Google Drive (lo que ya tenías) ──
DRIVE_FOLDER_ID=...
DRIVE_CREDENTIALS_PATH=credentials/service_account.json