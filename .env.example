# ── Copia este archivo como .env y rellena los valores ──────────────────────
# El archivo .env NUNCA se sube a git (está en .gitignore).

# ID de la carpeta de Google Drive donde se suben los Excel.
# Lo encuentras en la URL: drive.google.com/drive/folders/ESTE_ES_EL_ID
DRIVE_FOLDER_ID=pon_aqui_el_id_de_tu_carpeta

# Ruta al JSON de la Service Account (relativa a la raíz del proyecto).
# Por defecto: credentials/service_account.json
DRIVE_CREDENTIALS_PATH=credentials/service_account.json
